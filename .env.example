# ─── NextHub Core — Environment Variables ────────────────────────────────────
# Copy to .env and fill in your values.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://nexthub:password@localhost:5432/nexthub_db

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
REGULATOR_JWT_SECRET=change-me-regulator-min-32-chars

# ─── gRPC Server ─────────────────────────────────────────────────────────────
# Port NextHub's gRPC server listens on (Paygate connects here)
GRPC_PORT=50051
# Set to "true" to enable TLS on the gRPC server
GRPC_TLS=false

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# ─── Fluvio ──────────────────────────────────────────────────────────────────
FLUVIO_ENDPOINT=localhost:9003

# ─── S3 / Object Storage ─────────────────────────────────────────────────────
S3_BUCKET=nexthub-documents
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Keycloak (optional — for SSO) ───────────────────────────────────────────
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=nexthub
# KEYCLOAK_CLIENT_ID=nexthub-core

# ─── Redis (optional — for caching) ──────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the REST API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Integration API ─────────────────────────────────────────────────────────
# API key that Paygate must present in X-API-Key header
NEXTHUB_INTEGRATION_API_KEY=change-me-integration-api-key

# ─── Mojaloop / FSPIOP ───────────────────────────────────────────────────────
# MOJALOOP_HUB_URL=http://localhost:3003
# FSPIOP_SOURCE=nexthub

# ─── Face Biometric Service ───────────────────────────────────────────────────
FACE_BIOMETRIC_URL=http://localhost:8220
FACE_VERIFY_THRESHOLD=0.40
FACE_QUALITY_MIN_SCORE=0.60
FACE_LIVENESS_THRESHOLD=0.60
BIAS_AUDIT_SERVICE_URL=http://localhost:8230

# ─── Qdrant Vector Database ───────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── NINAuth / NIMC Integration ──────────────────────────────────────────────
NINAUTH_BASE_URL=https://ninauth.nimc.gov.ng
NINAUTH_CLIENT_ID=your-ninauth-client-id
NINAUTH_CLIENT_SECRET=your-ninauth-client-secret
NINAUTH_REDIRECT_URI=http://localhost:3000/api/ninauth/callback
NINAUTH_JWKS_URI=https://ninauth.nimc.gov.ng/.well-known/jwks.json
NINAUTH_ISSUER=https://ninauth.nimc.gov.ng
NIMC_API_URL=https://api.nimc.gov.ng/v1
NIMC_API_KEY=your-nimc-api-key

# ─── MOSIP Integration ────────────────────────────────────────────────────────
MOSIP_PREREG_BASE_URL=https://prereg.mosip.net/v1
MOSIP_REGPROC_BASE_URL=https://regproc.mosip.net/v1
MOSIP_IDREPO_BASE_URL=https://idrepo.mosip.net/v1
MOSIP_IDA_URL=https://ida.mosip.net/v1
MOSIP_IDA_PARTNER_ID=your-partner-id
MOSIP_IDA_API_KEY=your-ida-api-key
MOSIP_IDA_MISP_KEY=your-misp-key
MOSIP_CREDENTIAL_BASE_URL=https://credential.mosip.net/v1
MOSIP_VC_ISSUER_URL=https://esignet.mosip.net
ESIGNET_URL=https://esignet.mosip.net
ESIGNET_CLIENT_ID=your-esignet-client-id
ESIGNET_CLIENT_SECRET=your-esignet-client-secret
ESIGNET_REDIRECT_URI=http://localhost:3000/api/esignet/callback

# ─── Go Bridge ────────────────────────────────────────────────────────────────
MIDDLEWARE_BRIDGE_URL=http://localhost:8200
MIDDLEWARE_INTERNAL_KEY=change-me-bridge-internal-key-32chars

# ─── Permify (Authorization) ─────────────────────────────────────────────────
PERMIFY_URL=http://localhost:3476
PERMIFY_API_KEY=change-me-permify-key

# ─── Temporal (Workflow Orchestration) ───────────────────────────────────────
TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_NAMESPACE=nexthub
TEMPORAL_WORKFLOW_UI_URL=http://localhost:8088
TEMPORAL_API_URL=http://localhost:7233

# ─── NIBSS / NIP Integration ─────────────────────────────────────────────────
NIBSS_GATEWAY_URL=https://nibss-gateway.example.com
NIBSS_INSTITUTION_CODE=your-institution-code
NIBSS_SECRET_KEY=your-nibss-secret-key
NIBSS_BVN_API_URL=https://api.nibss-plc.com.ng/bvn
NIBSS_NIN_API_URL=https://api.nibss-plc.com.ng/nin
NIBSS_WEBHOOK_SECRET=change-me-nibss-webhook-secret

# ─── HSM Adapter ─────────────────────────────────────────────────────────────
HSM_ADAPTER_GRPC_REST_URL=http://localhost:8210
HSM_SLOT_ID=0
HSM_SLOT_PIN=change-me-hsm-pin

# ─── Keycloak SSO ─────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=nexthub
KEYCLOAK_CLIENT_ID=nexthub-core
KEYCLOAK_CLIENT_SECRET=change-me-keycloak-secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin-password
KEYCLOAK_WEBHOOK_SECRET=change-me-keycloak-webhook-secret

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=nexthub
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# ─── SMTP (Email Notifications) ──────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=change-me-smtp-password
