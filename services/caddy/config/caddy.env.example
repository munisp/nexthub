# ─────────────────────────────────────────────────────────────────────────────
# NextHub Caddy Edge Proxy — Environment Variables
# Copy to .env and fill in production values.
# ─────────────────────────────────────────────────────────────────────────────

# ACME / TLS
CADDY_ACME_EMAIL=ops@nexthub.io

# Domain names (override for each environment)
NEXTHUB_DOMAIN=hub.paygate.ng
NEXTHUB_API_DOMAIN=api.paygate.ng
NEXTHUB_GRPC_DOMAIN=grpc.paygate.ng
NEXTHUB_AUTH_DOMAIN=auth.paygate.ng

# Internal upstream addresses (Docker Compose service names)
NEXTHUB_UPSTREAM=http://nexthub:3001
APISIX_UPSTREAM=http://apisix:9080
KEYCLOAK_UPSTREAM=http://keycloak:8080
NEXTHUB_GRPC_UPSTREAM=nexthub:50051

# OpenAppSec
OPENAPPSEC_SOCKET=/run/appsec.sock
APPSEC_LOG_LEVEL=info

# Caddy Admin API (internal only — not exposed externally)
# CADDY_ADMIN_PORT=2019
