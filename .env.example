# ─── NextHub Core — Environment Variables ────────────────────────────────────
# Copy to .env and fill in your values.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://nexthub:password@localhost:5432/nexthub_db

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
REGULATOR_JWT_SECRET=change-me-regulator-min-32-chars

# ─── gRPC Server ─────────────────────────────────────────────────────────────
# Port NextHub's gRPC server listens on (Paygate connects here)
GRPC_PORT=50051
# Set to "true" to enable TLS on the gRPC server
GRPC_TLS=false

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# ─── Fluvio ──────────────────────────────────────────────────────────────────
FLUVIO_ENDPOINT=localhost:9003

# ─── S3 / Object Storage ─────────────────────────────────────────────────────
S3_BUCKET=nexthub-documents
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Keycloak (optional — for SSO) ───────────────────────────────────────────
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=nexthub
# KEYCLOAK_CLIENT_ID=nexthub-core

# ─── Redis (optional — for caching) ──────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the REST API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Integration API ─────────────────────────────────────────────────────────
# API key that Paygate must present in X-API-Key header
NEXTHUB_INTEGRATION_API_KEY=change-me-integration-api-key

# ─── Mojaloop / FSPIOP ───────────────────────────────────────────────────────
# MOJALOOP_HUB_URL=http://localhost:3003
# FSPIOP_SOURCE=nexthub
